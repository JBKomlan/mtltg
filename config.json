{
  "project_metadata": {
    "name": "TransferLink",
    "version": "4.2",
    "base_currency": "XOF",
    "default_country_code": "TG"
  },
  "regional_settings": {
    "TG": {
      "country_name": "Togo",
      "calling_code": "+228",
      "networks": {
        "tmoney": {
          "provider_label": "Mixx by Yas",
          "prefixes": ["90", "91", "92", "93", "70", "71", "72"],
          "ussd_templates": {
            "national": "*145*1*{{amount}}*{{phone}}*{{suffix}}#"
          }
        },
        "flooz": {
          "provider_label": "Moov Money Flooz",
          "prefixes": ["96", "97", "98", "99", "79"],
          "ussd_templates": {
            "national": "*155*1*1*{{phone}}*{{phone}}*{{amount}}*{{suffix}}#",
            "international": "*155*1*4*{{phone}}*{{amount}}#"
          }
        }
      }
    }
  },
